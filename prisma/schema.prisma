// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =========================
// CLIENTES
// =========================
model Cliente {
  id_cliente        Int       @id @default(autoincrement())
  rut              String?   @db.VarChar(12)
  primer_nombre    String?   @db.VarChar(50)
  segundo_nombre   String?   @db.VarChar(50)
  apellido_paterno String?   @db.VarChar(50)
  apellido_materno String?   @db.VarChar(50)
  email            String    @unique @db.VarChar(100)
  telefono         String?   @db.VarChar(20)
  password_hash    String
  direcciones      Direccion[]
  pedidos          Pedido[]
  reservas         Reserva[]

  @@map("Clientes")
}

// =========================
// DIRECCIONES
// =========================
model Direccion {
  id_direccion   Int      @id @default(autoincrement())
  id_cliente     Int
  pais           String?  @db.VarChar(50)
  region         String?  @db.VarChar(50)
  ciudad         String?  @db.VarChar(50)
  comuna         String?  @db.VarChar(50)
  direccion      String?  @db.Text
  codigo_postal  String?  @db.VarChar(10)
  alias          String?  @db.VarChar(50)
  tipo           String?  @db.VarChar(20)
  cliente        Cliente  @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  envios         Envio[]

  @@map("Direcciones")
}

// =========================
// CATEGORIAS
// =========================
model Categoria {
  id_categoria Int         @id @default(autoincrement())
  nombre       String      @db.VarChar(50)
  productos    Producto[]

  @@map("Categorias")
}

// =========================
// PRODUCTOS
// =========================
model Producto {
  id_producto       Int             @id @default(autoincrement())
  nombre            String          @db.VarChar(100)
  nombre_cientifico String?         @db.VarChar(100)
  descripcion       String?         @db.Text
  id_categoria      Int?
  tipo_venta        String?         @default("normal") @db.VarChar(20)
  stock_total       Int             @default(0)
  stock_reservado   Int             @default(0)
  precio_venta      Decimal         @db.Decimal(10, 2)
  precio_costo      Decimal?        @db.Decimal(10, 2)
  estado            String?         @db.VarChar(20)
  categoria         Categoria?      @relation(fields: [id_categoria], references: [id_categoria])
  imagenes_producto ImagenProducto[]
  detalle_compras   DetalleCompra[]
  detalle_pedidos   DetallePedido[]
  reservas          Reserva[]

  @@map("Productos")
}

// =========================
// IMAGENES PRODUCTOS
// =========================
model ImagenProducto {
  id_imagen   Int      @id @default(autoincrement())
  id_producto Int
  url         String   @db.Text
  es_principal Boolean @default(false)
  orden       Int      @default(0)
  producto    Producto @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade)

  @@map("imagenes_productos")
}

// =========================
// PROVEEDORES
// =========================
model Proveedor {
  id_proveedor Int         @id @default(autoincrement())
  nombre       String?     @db.VarChar(100)
  rut          String?     @db.VarChar(12)
  telefono     String?     @db.VarChar(20)
  correo       String?     @db.VarChar(100)
  compras      Compra[]
  gastos       Gasto[]

  @@map("Proveedores")
}

// =========================
// COMPRAS
// =========================
model Compra {
  id_compra Int            @id @default(autoincrement())
  id_proveedor Int
  fecha     DateTime       @default(now())
  subtotal  Decimal?       @db.Decimal(10, 2)
  iva       Decimal?       @db.Decimal(10, 2)
  total     Decimal?       @db.Decimal(10, 2)
  proveedor Proveedor      @relation(fields: [id_proveedor], references: [id_proveedor])
  detalles  DetalleCompra[]

  @@map("Compras")
}

// =========================
// DETALLE COMPRA
// =========================
model DetalleCompra {
  id_detalle       Int      @id @default(autoincrement())
  id_compra        Int
  id_producto      Int
  cantidad         Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  compra           Compra   @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade)
  producto         Producto @relation(fields: [id_producto], references: [id_producto])

  @@map("DetalleCompra")
}

// =========================
// PEDIDOS
// =========================
model Pedido {
  id_pedido    Int             @id @default(autoincrement())
  id_cliente   Int
  fecha        DateTime        @default(now())
  estado       String          @db.VarChar(50)
  total        Decimal         @db.Decimal(10, 2)
  cliente      Cliente         @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade)
  detalles     DetallePedido[]
  pagos        Pago[]
  envios       Envio[]
  historial    HistorialPedido[]

  @@map("Pedidos")
}

// =========================
// DETALLE PEDIDO
// =========================
model DetallePedido {
  id_detalle       Int      @id @default(autoincrement())
  id_pedido        Int
  id_producto      Int
  cantidad         Int
  precio_unitario Decimal  @db.Decimal(10, 2)
  pedido           Pedido   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  producto         Producto @relation(fields: [id_producto], references: [id_producto])

  @@map("DetallePedido")
}

// =========================
// PAGOS
// =========================
model Pago {
  id_pago       Int      @id @default(autoincrement())
  id_pedido     Int
  metodo        String?  @db.VarChar(50)
  estado        String?  @db.VarChar(50)
  monto         Decimal? @db.Decimal(10, 2)
  transaction_id String?  @db.VarChar(100)
  fecha         DateTime @default(now())
  pedido        Pedido   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)

  @@map("Pagos")
}

// =========================
// ENVIOS
// =========================
model Envio {
  id_envio        Int        @id @default(autoincrement())
  id_pedido       Int
  id_direccion    Int
  fecha           DateTime?
  costo           Decimal?   @db.Decimal(10, 2)
  tracking        String?    @db.VarChar(100)
  estado          String?    @db.VarChar(50)
  direccion_texto String?    @db.Text
  ciudad          String?    @db.VarChar(50)
  region          String?    @db.VarChar(50)
  comuna          String?    @db.VarChar(50)
  pedido          Pedido     @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  direccion       Direccion  @relation(fields: [id_direccion], references: [id_direccion])

  @@map("Envios")
}

// =========================
// RESERVAS (PREVENTA)
// =========================
model Reserva {
  id_reserva        Int      @id @default(autoincrement())
  id_producto       Int
  id_cliente        Int
  cantidad          Int
  fecha_expiracion  DateTime
  estado            String?  @db.VarChar(20)
  producto          Producto @relation(fields: [id_producto], references: [id_producto])
  cliente           Cliente  @relation(fields: [id_cliente], references: [id_cliente])

  @@map("Reservas")
}

// =========================
// EMPLEADOS
// =========================
model Empleado {
  id_empleado   Int    @id @default(autoincrement())
  rut          String? @db.VarChar(12)
  nombre       String? @db.VarChar(100)
  email        String? @db.VarChar(100)
  telefono     String? @db.VarChar(20)
  password_hash String? @db.Text
  cargo        String? @db.VarChar(50)
  estado       String? @db.VarChar(20)
  historial    HistorialPedido[]

  @@map("Empleados")
}

// =========================
// HISTORIAL PEDIDO (OPCIONAL)
// =========================
model HistorialPedido {
  id          Int       @id @default(autoincrement())
  id_pedido   Int
  id_empleado Int?
  estado      String?   @db.VarChar(50)
  fecha       DateTime  @default(now())
  pedido      Pedido    @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade)
  empleado    Empleado? @relation(fields: [id_empleado], references: [id_empleado])

  @@map("HistorialPedido")
}

// =========================
// GASTOS (OPCIONAL)
// =========================
model Gasto {
  id_gasto   Int       @id @default(autoincrement())
  id_proveedor Int?
  tipo       String?   @db.VarChar(50)
  descripcion String?   @db.Text
  monto      Decimal?  @db.Decimal(10, 2)
  fecha      DateTime  @default(now())
  proveedor  Proveedor? @relation(fields: [id_proveedor], references: [id_proveedor])

  @@map("Gastos")
}
